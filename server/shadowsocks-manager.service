[Unit]
Description=Shadowsocks Libev Manager (ss-manager)
After=network.target

[Service]
Type=simple
User=root
ExecStart=/usr/local/bin/ss-manager -u --manager-address 127.0.0.1:6001 --workdir /var/lib/shadowsocks-manager -s 0.0.0.0 -m chacha20-ietf-poly1305
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
